<!DOCTYPE html>
<html lang="en">
<head><link rel="icon" type="image/png" href="images/logo.png">
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aya Mohamed | Mechanical &amp; Aerospace Engineering Portfolio</title>
<meta name="description" content="Aya Mohamed — M.S. Mechanical & Aerospace Engineering, UC Irvine. Fluid dynamics, propulsion, and prototyping.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600&display=swap" rel="stylesheet">
<style>
  html{scroll-behavior:smooth;}
  .section{scroll-margin-top:90px;}
  #top{scroll-margin-top:0;}
  #contact{scroll-margin-top:90px;}
  :root{
    --dark:#0d0d0f;
    --accent-bronze:#9c7a3c;
    --navy:#3a5f85;
    --grey-text:#6b6b6b;
    --light-grey:#f4f4f4;
    --border:#e2e2e2;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{
    font-family:'Poppins', sans-serif;
    color:#1a1a1a;
    background:#fff;
  }
  a{text-decoration:none;color:inherit;}
  img, .ph{display:block; width:100%; height:100%; object-fit:cover;}
  .gallery-trigger{position:relative; cursor:pointer; overflow:hidden;}
  .gallery-trigger img, .gallery-trigger video{width:100%; height:100%; object-fit:cover; transition:transform .35s ease;}
  .gallery-trigger:hover img, .gallery-trigger:hover video{transform:scale(1.05);}
  .gallery-trigger .img-count{
    position:absolute; bottom:8px; right:8px;
    background:rgba(0,0,0,0.6); color:#fff;
    font-size:0.7rem; letter-spacing:.03em;
    padding:3px 8px; border-radius:12px;
  }
  .section{padding:100px 8vw;}
  @media (max-width:700px){ .section{padding:60px 6vw;} }

  /* placeholder image blocks */
  .ph{
    background:linear-gradient(135deg,#dfe3e6,#c7ccd1);
    display:flex;align-items:center;justify-content:center;
    color:#8a8f96;font-size:0.75rem;letter-spacing:.05em;
    text-transform:uppercase;
    text-align:center;
    padding:10px;
  }

  /* ---------------- HERO ---------------- */
  .hero{
    background:#0d0d0f;
    color:#fff;
    min-height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
    text-align:center;
    padding:80px 6vw;
    position:relative;
    overflow:hidden;
  }
  .hero-video{
    position:absolute;
    inset:0;
    width:100%;
    height:100%;
    object-fit:cover;
    z-index:0;
  }
  .hero-overlay{
    position:absolute;
    inset:0;
    background:rgba(10,10,12,0.55);
    z-index:1;
  }
  .hero-inner{max-width:760px; position:relative; z-index:2;}
  .hero h1{
    font-family:'Playfair Display', serif;
    font-weight:600;
    font-size:clamp(2.6rem,8vw,5rem);
    line-height:1.05;
    margin-bottom:36px;
  }
  .hero .subtitle{
    font-size:1.3rem;
    font-weight:300;
    margin-bottom:14px;
  }
  .hero .role{
    font-size:1.1rem;
    font-weight:400;
    color:#c9c9c9;
    margin:18px 0 30px;
  }
  .hero .tagline{
    font-size:1.15rem;
    font-weight:600;
    letter-spacing:.02em;
    margin-bottom:36px;
  }
  .hero-badges{
    display:flex;flex-wrap:wrap;gap:10px;justify-content:center;
    max-width:640px;margin:0 auto;
  }
  .hbadge{
    font-size:0.75rem;letter-spacing:.03em;text-transform:uppercase;
    border:1px solid rgba(255,255,255,0.25);color:#e8e8e8;
    padding:8px 14px;border-radius:20px;
  }
  .hero-cta{
    margin-top:32px;
    display:flex;
    justify-content:center;
  }
  .btn-download-cv{
    display:inline-flex;
    align-items:center;
    gap:10px;
    background:#fff;
    color:var(--navy);
    border:none;
    border-radius:30px;
    padding:14px 32px;
    font-family:'Poppins',sans-serif;
    font-size:0.95rem;
    font-weight:600;
    letter-spacing:.02em;
    text-decoration:none;
    transition:background .2s, transform .2s;
  }
  .btn-download-cv:hover{
    background:#e8e8e8;
    transform:translateY(-2px);
  }

  /* ---------------- SECTION HEADER ---------------- */
  h2.section-title{
    font-size:2.6rem;
    font-weight:400;
    color:#1a1a1a;
    margin-bottom:16px;
  }
  p.section-sub{
    color:var(--grey-text);
    font-size:1rem;
    max-width:60ch;
    margin-bottom:60px;
    line-height:1.7;
  }

  /* ---------------- STATS BAND ---------------- */
  .stats-band{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    border-top:1px solid var(--border);
    border-bottom:1px solid var(--border);
  }
  .stats-band .stat{
    padding:40px 20px;
    text-align:center;
    border-right:1px solid var(--border);
  }
  .stats-band .stat:last-child{border-right:none;}
  .stats-band .stat .num{
    font-family:'Playfair Display', serif;
    font-size:2.4rem;
    color:var(--navy);
  }
  .stats-band .stat .lab{
    font-size:0.8rem;
    letter-spacing:.04em;
    text-transform:uppercase;
    color:var(--grey-text);
    margin-top:6px;
  }
  @media (max-width:700px){
    .stats-band{grid-template-columns:repeat(2,1fr);}
    .stats-band .stat:nth-child(2){border-right:none;}
  }

  /* ---------------- EXPERIENCE ROWS ---------------- */
  .exp-row{
    display:grid;
    grid-template-columns:340px 1fr;
    gap:60px;
    align-items:center;
    margin-bottom:90px;
  }
  .exp-row:last-child{margin-bottom:0;}
  .exp-row.no-img{grid-template-columns:1fr; max-width:74ch;}
  .exp-row.img-right{grid-template-columns:1fr 300px;}
  .exp-row.img-right .exp-img{order:2;}
  @media (max-width:800px){
    .exp-row{grid-template-columns:1fr; gap:24px;}
    .exp-row.img-right .exp-img{order:0;}
  }
  .edu-wrap{
    display:grid;
    grid-template-columns:1fr 380px;
    gap:60px;
    align-items:start;
  }
  .edu-wrap .edu-text .exp-row{margin-bottom:70px;}
  .edu-wrap .edu-text .exp-row:last-child{margin-bottom:0;}
  .edu-photo{
    aspect-ratio:3/4;
    border-radius:8px;
    overflow:hidden;
    position:sticky;
    top:110px;
  }
  @media (max-width:900px){
    .edu-wrap{grid-template-columns:1fr;}
    .edu-photo{aspect-ratio:16/9; position:static;}
  }
  .exp-row .exp-img{
    aspect-ratio:4/3;
    border-radius:8px;
    overflow:hidden;
  }
  .exp-row h3{
    font-size:1.5rem;
    font-weight:600;
    margin-bottom:4px;
  }
  .exp-row .org{
    font-style:italic;
    font-weight:400;
    font-size:1.1rem;
    display:block;
    margin-bottom:6px;
  }
  .exp-row .meta{
    font-size:0.85rem;
    letter-spacing:.03em;
    text-transform:uppercase;
    color:var(--navy);
    margin-bottom:16px;
    display:block;
  }
  .exp-row p{
    color:var(--grey-text);
    font-size:1rem;
    line-height:1.7;
    max-width:60ch;
  }
  .exp-row ul{
    color:var(--grey-text);
    font-size:0.98rem;
    line-height:1.7;
    max-width:62ch;
    padding-left:20px;
    margin-top:8px;
  }
  .exp-row li{margin-bottom:6px;}

  /* ---------------- EXPERIENCE / INTERNSHIP BOXED GRID ---------------- */
  .exp-grid{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:32px;
  }
  @media (max-width:800px){ .exp-grid{grid-template-columns:1fr;} }
  .exp-grid .exp-row{
    background:#fff;
    border:1px solid var(--border);
    border-radius:14px;
    padding:34px;
    margin-bottom:0;
    max-width:none;
    box-shadow:0 4px 18px rgba(0,0,0,0.045);
    transition:transform .25s ease, box-shadow .25s ease;
  }
  .exp-grid .exp-row:hover{
    transform:translateY(-5px);
    box-shadow:0 14px 34px rgba(0,0,0,0.09);
  }
  .exp-grid .exp-row p,
  .exp-grid .exp-row ul{max-width:none;}
  .row-chips{display:flex;flex-wrap:wrap;gap:8px;margin-top:16px;}
  .row-chips .chip{
    font-size:0.78rem;
    color:var(--navy);
    border:1px solid var(--navy);
    padding:5px 12px;
    border-radius:20px;
  }

  /* ---------------- CARD GRID (Skills / Papers / Projects / Awards) ---------------- */
  .card-grid{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:28px;
  }
  .card-grid.three{grid-template-columns:repeat(3,1fr);}
  @media (max-width:900px){
    .card-grid, .card-grid.three{grid-template-columns:1fr;}
  }
  .card{
    border:1px solid var(--border);
    border-radius:8px;
    overflow:hidden;
    display:flex;
    flex-direction:column;
    transition:box-shadow .2s, transform .2s;
  }
  .card:hover{box-shadow:0 10px 30px rgba(0,0,0,0.07); transform:translateY(-2px);}
  .card .card-img{aspect-ratio:16/10;}
  .card .card-body{padding:26px 28px;flex:1;display:flex;flex-direction:column;}
  .card .tag-eyebrow{
    font-size:0.75rem;letter-spacing:.05em;text-transform:uppercase;
    color:var(--navy);margin-bottom:10px;
  }
  .card .tag-eyebrow.published{
  color:var(--accent-bronze);
}
  .card h3{font-size:1.2rem;font-weight:600;margin-bottom:10px;line-height:1.3;}
  .card p{color:var(--grey-text);font-size:0.93rem;line-height:1.65;flex:1;}
  .card .doi-line{
  font-size:0.8rem;margin-top:6px;
}
.card .doi-line a{
  color:var(--navy);text-decoration:none;border-bottom:1px solid var(--navy);
}
.card .doi-line a:hover{color:var(--accent-bronze);border-bottom-color:var(--accent-bronze);}
  .card .impact{
    margin-top:14px;padding-left:12px;border-left:2px solid var(--navy);
    color:var(--navy);font-size:0.85rem;font-weight:500;
  }
  .card .meta-line{
    font-size:0.8rem;color:#9a9a9a;margin-top:auto;padding-top:14px;
    border-top:1px solid var(--border);margin-top:16px;
  }
  #internships .card{padding:2px 0;}
  #internships .card-body{padding:24px 28px;}
  #internships .card-body p{max-width:80ch;}

  /* filter buttons for projects */
  .filters{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:44px;}
  .filter-btn{
    font-size:0.85rem;letter-spacing:.02em;text-transform:uppercase;
    padding:10px 20px;border:1px solid var(--navy);color:var(--navy);
    background:transparent;border-radius:24px;cursor:pointer;transition:all .2s;
  }
  .filter-btn:hover, .filter-btn.active{background:var(--navy);color:#fff;}
  .project-card.hide, .award-card.hide{display:none;}

  /* awards mini-card (denser, 15 items) */
  .award-card{
    border:1px solid var(--border);
    border-radius:8px;
    overflow:hidden;
    transition:box-shadow .2s, transform .2s;
  }
  .award-card:hover{box-shadow:0 10px 24px rgba(0,0,0,0.06); transform:translateY(-2px);}
  .award-card .card-img{aspect-ratio:16/10;}
  .award-card .award-body{padding:22px 24px;}
  .award-card .rank{
    font-size:0.78rem;letter-spacing:.04em;text-transform:uppercase;
    color:var(--navy);font-weight:600;
  }
  .award-card h3{font-size:1.05rem;font-weight:600;margin:8px 0 4px;}
  .award-card .meta{font-size:0.8rem;color:#9a9a9a;margin-bottom:10px;display:block;}
  .award-card p{color:var(--grey-text);font-size:0.9rem;line-height:1.6;}
  .award-card a{color:var(--navy);font-weight:600;}

  /* skills bars */
  .skill-col h4{
    font-size:0.85rem;letter-spacing:.05em;text-transform:uppercase;
    color:var(--navy);margin-bottom:22px;
  }
  .skill-row{margin-bottom:18px;}
  .skill-row .top{display:flex;justify-content:space-between;font-size:0.92rem;margin-bottom:7px;}
  .skill-row .top .pct{color:#9a9a9a;font-size:0.82rem;}
  .bar{height:5px;background:var(--light-grey);border-radius:4px;overflow:hidden;}
  .bar span{display:block;height:100%;background:var(--navy);border-radius:4px;}

  /* ---------------- GALLERY ---------------- */
  .gallery-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:24px;
  }
  @media (max-width:800px){ .gallery-grid{grid-template-columns:repeat(2,1fr);} }
  .gallery-grid .g-item{
    aspect-ratio:1;
    border-radius:8px;
    overflow:hidden;
  }

  /* ---------------- CONTACT ---------------- */
  #contact{padding:100px 8vw;}
  .contact-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:60px;
    align-items:start;
  }
  @media (max-width:800px){ .contact-grid{grid-template-columns:1fr;} }
  .contact-grid .eyebrow{
    font-size:0.8rem;
    letter-spacing:.08em;
    text-transform:uppercase;
    color:var(--navy);
    margin-bottom:16px;
    display:block;
    font-weight:600;
  }
  .contact-grid h2{
    font-size:clamp(2rem,4vw,2.6rem);
    font-weight:400;
    line-height:1.15;
    margin-bottom:18px;
  }
  .contact-grid p.lede{
    color:var(--grey-text);
    font-size:1rem;
    max-width:44ch;
    margin-bottom:36px;
  }
  .contact-links{
    display:flex;
    flex-direction:column;
    gap:16px;
  }
  .clink{
    display:flex;
    align-items:center;
    gap:14px;
    font-size:0.98rem;
    color:var(--grey-text);
    transition:color .2s;
  }
  .clink:hover{color:var(--navy);}
  .clink .ic{
    width:36px;height:36px;
    border:1px solid var(--border);
    border-radius:6px;
    display:flex;align-items:center;justify-content:center;
    color:var(--navy);
    flex-shrink:0;
    font-size:0.95rem;
  }
  #contactForm{display:flex;flex-direction:column;gap:20px;}
  #contactForm .field label{
    display:block;
    font-size:0.85rem;
    color:#3a3a3a;
    margin-bottom:8px;
  }
  #contactForm input,
  #contactForm textarea{
    width:100%;
    border:1px solid var(--border);
    border-radius:6px;
    padding:14px 16px;
    font-family:'Poppins',sans-serif;
    font-size:0.95rem;
    background:#fff;
  }
  #contactForm textarea{min-height:110px; resize:vertical;}
  .btn.btn-primary{
    background:var(--navy);
    color:#fff;
    border:none;
    border-radius:30px;
    padding:15px 40px;
    font-family:'Poppins',sans-serif;
    font-size:0.95rem;
    font-weight:500;
    cursor:pointer;
    align-self:flex-start;
    transition:background .2s;
    display:inline-flex;
    align-items:center;
    gap:8px;
  }
  .btn.btn-primary:hover{background:#2e4d6b;}

  /* ---------------- SOCIAL / EMAIL BAND ---------------- */
  .social-band{
    background:var(--navy);
    color:#fff;
    padding:70px 8vw;
    display:flex;
    flex-wrap:wrap;
    justify-content:space-between;
    align-items:center;
    gap:30px;
  }
  .social-band .linkedin{
    display:flex;
    align-items:center;
    gap:14px;
    font-size:1.4rem;
    font-weight:500;
  }
  .social-band .linkedin .li-icon{
    width:36px;height:36px;
    background:#fff;
    color:var(--navy);
    border-radius:6px;
    display:flex;align-items:center;justify-content:center;
    font-weight:700;
    font-size:1.1rem;
  }
  .social-band .facebook{
    display:flex;
    align-items:center;
    gap:14px;
    font-size:1.4rem;
    font-weight:500;
  }
  .social-band .facebook .fb-icon{
    width:36px;height:36px;
    background:#fff;
    color:var(--navy);
    border-radius:6px;
    display:flex;align-items:center;justify-content:center;
    font-weight:700;
    font-size:1.1rem;
  }
  .social-band .social-cv{
    display:flex;
    align-items:center;
    gap:14px;
    font-size:1.4rem;
    font-weight:500;
  }
  .social-band .social-cv .cv-icon{
    width:36px;height:36px;
    background:#fff;
    color:var(--navy);
    border-radius:6px;
    display:flex;align-items:center;justify-content:center;
    font-weight:700;
    font-size:1.1rem;
  }
  .social-band .social-links{
    display:flex;
    flex-wrap:wrap;
    align-items:center;
    gap:280px;
  }
  .social-band .emails{
    text-align:right;
    font-size:1.05rem;
    line-height:1.8;
  }
  @media (max-width:600px){ .social-band{flex-direction:column; align-items:flex-start;} .social-band .emails{text-align:left;} }

  /* ---------------- FOOTER NAV ---------------- */
  header.site-header{
    padding:26px 8vw;
    display:flex;
    align-items:center;
    justify-content:space-between;
    border-bottom:1px solid var(--border);
    flex-wrap:wrap;
    gap:20px;
    position:sticky;top:0;background:#fff;z-index:50;
  }
  header.site-header .logo{
    font-family:'Playfair Display', serif;
    font-size:1.4rem;
    font-weight:600;
    display:flex;align-items:center;gap:4px;
  }
  header.site-header .logo img{
    height:40px;
    width:auto;
    display:block;
  }
  header.site-header nav{
    display:flex;
    gap:50px;
    font-size:0.9rem;
    flex-wrap:wrap;
  }
  header.site-header nav a{
    padding-bottom:6px;
  }
  header.site-header nav a.active{
    border-bottom:2px solid #1a1a1a;
  }
  @media (max-width:900px){ header.site-header nav{gap:14px; font-size:0.78rem;} }

  footer.site-footer{
    padding:30px 8vw;
    text-align:center;
    color:var(--grey-text);
    font-size:0.85rem;
    border-top:1px solid var(--border);
  }
</style>
</head>
<body>

  <!-- HEADER NAV -->
  <header class="site-header">
    <div class="logo"><a href="#top"><img src="images/logo.png" alt="Aya Mohamed"></a></div>
    <nav>
      <a href="#top" class="active">Home</a>
      <a href="#education">Education</a>
      <a href="#experience">Experience</a>
      <a href="#internships">Internships</a>
      <a href="#skills">Skills</a>
      <a href="#papers">Research</a>
      <a href="#projects">Projects</a>
      <a href="#awards">Awards</a>
      <a href="#certificates">Certificates</a>
      <a href="#gallery">Gallery</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <!-- HERO -->
  <section class="hero" id="top">
    <video class="hero-video" autoplay muted loop playsinline>
      <source src="images/cover.mp4" type="video/mp4">
    </video>
    <div class="hero-overlay"></div>
    <div class="hero-inner">
      <h1>Aya Mohamed</h1>
      <p class="subtitle">Mechanical &amp; Aerospace Engineering</p>
      <p class="subtitle" style="margin-top:-8px;">M.S. Student, UC Irvine</p>
      <p class="role">Fluid Dynamics &amp; Propulsion Researcher | Control Systems TA</p>
      <p class="tagline">Turning engineering ideas into things that fly.</p>
      <div class="hero-badges">
        <span class="hbadge">1st · NASA Space Apps</span>
        <span class="hbadge">1st · IEEE Mobility Challenge</span>
        <span class="hbadge">Gold · ICAN Innovation</span>
        <span class="hbadge">2nd · Minesweeper Intl.</span>
        <span class="hbadge">3rd · Eurocontrol Ideathon</span>
      </div>
      <div class="hero-cta">
        <a class="btn-download-cv" href="https://drive.google.com/drive/folders/1D7YjPT8bx4U-fN9mTvsYXHnhiZIiKRhi?usp=sharing" download>
          <span>⬇</span> Download CV
        </a>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <div class="stats-band">
    <div class="stat"><div class="num" data-target="3" data-suffix="+">0</div><div class="lab">Years Engineering</div></div>
    <div class="stat"><div class="num" data-target="20" data-suffix="+">0</div><div class="lab">Major Projects</div></div>
    <div class="stat"><div class="num" data-target="18" data-suffix="">0</div><div class="lab">Awards &amp; Competitions</div></div>
    <div class="stat"><div class="num" data-target="40000" data-prefix="$" data-suffix="">0</div><div class="lab">Scholarships &amp; Awards</div></div>
  </div>

  <!-- EDUCATION -->
  <section class="section" id="education">
    <h2 class="section-title">Education</h2>

    <div class="edu-wrap">
      <div class="edu-text">
        <div class="exp-row no-img">
          <div>
            <h3>M.S. Mechanical &amp; Aerospace Engineering</h3>
            <span class="org">University of California, Irvine — Henry Samueli School of Engineering</span>
            <span class="meta">Mar 2025 — May 2027 · California, USA</span>
            <p>Specializing in Fluid Dynamics &amp; Propulsion. Currently a Control Systems Teaching Assistant and graduate researcher running direct numerical simulations of turbulence.</p>
            <div class="row-chips">
              <span class="chip">Fluid Dynamics</span>
              <span class="chip">Propulsion</span>
              <span class="chip">Control Systems TA</span>
            </div>
          </div>
        </div>

